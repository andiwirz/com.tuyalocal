        "titleFormatted": {
          "en": "Humidity went above [[humidity]]%",
          "de": "Luftfeuchtigkeit überschreitet [[humidity]]%"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=dehumidifier"
          },
          {
            "name": "humidity",
            "type": "number",
            "min": 0,
            "max": 100,
            "step": 1,
            "title": {
              "en": "Humidity (%)",
              "de": "Luftfeuchtigkeit (%)"
